        "competition_matches_next_match_slot_valid": {
          "name": "competition_matches_next_match_slot_valid",
          "value": "`competition_matches`.`next_match_slot` is null or `competition_matches`.`next_match_slot` in (1, 2)"
        },
        "competition_matches_completed_requires_resolution": {
          "name": "competition_matches_completed_requires_resolution",
          "value": "`competition_matches`.`status` <> 'completed' or `competition_matches`.`resolution_type` is not null"
        },
        "competition_matches_bye_shape": {
          "name": "competition_matches_bye_shape",
          "value": "`competition_matches`.`resolution_type` <> 'bye' or (\n        (\n          `competition_matches`.`slot1_participant_id` is not null and\n          `competition_matches`.`slot2_participant_id` is null and\n          `competition_matches`.`winner_participant_id` = `competition_matches`.`slot1_participant_id`\n        ) or (\n          `competition_matches`.`slot2_participant_id` is not null and\n          `competition_matches`.`slot1_participant_id` is null and\n          `competition_matches`.`winner_participant_id` = `competition_matches`.`slot2_participant_id`\n        )\n      )"
        },
        "competition_matches_played_shape": {
          "name": "competition_matches_played_shape",
          "value": "`competition_matches`.`resolution_type` <> 'played' or (\n        `competition_matches`.`slot1_participant_id` is not null and\n        `competition_matches`.`slot2_participant_id` is not null and\n        `competition_matches`.`winner_participant_id` in (`competition_matches`.`slot1_participant_id`, `competition_matches`.`slot2_participant_id`) and\n        `competition_matches`.`slot1_score` is not null and\n        `competition_matches`.`slot2_score` is not null\n      )"
        }
      }
